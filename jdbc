  const q = DAYS[d-1];
  const arc = getArc(d);
  document.getElementById('day-disp').textContent = `JOUR ${d}`;
  document.getElementById('arc-name').textContent = arc.name;
  document.getElementById('arc-theme').textContent = arc.theme;

  const types = [
    { key:'phys', data:q.phys, cls:'phys', label:'PHYSIQUE' },
    { key:'ment', data:q.ment, cls:'ment', label:'MENTAL / CODE' },
    { key:'evol', data:q.evol, cls:'evol', label:'ÉVOLUTION' },
  ];

  const grid = document.getElementById('quest-grid');
  grid.innerHTML='';
  let comp=0, xpG=0;

  types.forEach(t=>{
    const k = `${d}_${t.key}`;
    const done = !!S.done[k];
    if(done){ comp++; xpG+=XP_Q; }

    const c = document.createElement('div');
    c.className = `q-card ${t.cls}${done?' done':''}`;
    c.innerHTML = `
      <div class="q-type-row">
        <div class="q-type">${t.label}</div>
        <div class="q-check">${done?'✓':''}</div>
      </div>
      <div class="q-icon">${t.data.icon}</div>
      <div class="q-title">${t.data.t}</div>
      <div class="q-desc">${t.data.desc}</div>
      <div class="q-xp">⚡ +${XP_Q} XP</div>`;

    c.onclick = ()=>{
      if(!done){
        S.done[k]=true; S.xp+=XP_Q; S.sqsts++;
        const allDone = types.every(tt=>!!S.done[`${d}_${tt.key}`]);
        if(allDone && !S.ddone[d]){
          S.ddone[d]=true; S.xp+=XP_DAY; S.sdays++; S.streak++;
          setTimeout(()=>showToast(`🏆 JOUR ${d} TERMINÉ ! +${XP_DAY} XP BONUS !`, 'purple'),400);
        } else {
          showToast(`+${XP_Q} XP — Quête validée`, 'gold');
        }
        checkLv(); saveS(); updateUI(); renderQuests(d); renderMap();
      }
    };
    grid.appendChild(c);
  });

  document.getElementById('qp-label').textContent = `${comp}/3`;
  document.getElementById('qp-fill').style.width = (comp/3*100)+'%';
  document.getElementById('qp-xp').textContent = `${xpG} XP`;
  document.getElementById('reward-text').textContent = comp>=3
    ? '🏆 Journée validée. Film, animé, musique — tu mérites ta soirée.'
    : `Complète les ${3-comp} quête(s) restante(s) pour débloquer ta soirée.`;
}

// ══════════════════════════
// MAP
// ══════════════════════════
function renderMap(){
  const g = document.getElementById('map-grid');
  g.innerHTML='';
  for(let d=1;d<=17;d++){
    const el = document.createElement('div');
    const done = !!S.ddone[d];
    const active = d===curDay;
    const boss = d===17;
    el.className = `map-day${done?' done':''}${active?' active':''}${boss?' boss':''}`;
    el.innerHTML = `<span class="map-day-n">${d}</span><span class="map-day-s">${done?'✓':boss?'👑':''}</span>`;
    el.onclick = ()=>{ curDay=d; renderQuests(d); renderMap(); };
    g.appendChild(el);
  }
}

// ══════════════════════════
// TOAST
// ══════════════════════════
let _tt = null;
function showToast(msg, type=''){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = `toast ${type} show`;
  if(_tt) clearTimeout(_tt);
  _tt = setTimeout(()=>{ t.className = `toast ${type}`; }, 3000);
}

// ══════════════════════════
// LEVEL UP OVERLAY
// ══════════════════════════
function checkLv(){
  const {lv} = getLv(S.xp);
  if(lv > (S.lv||1)){
    S.lv = lv;
    showLvlUp(lv);
  }
}

function showLvlUp(lv){
  const rk = getRank(lv);
  document.getElementById('lvlup-num').textContent = lv;
  document.getElementById('lvlup-title').textContent = LEVEL_TITLES[Math.min(lv-1, LEVEL_TITLES.length-1)].toUpperCase();
  document.getElementById('lvlup-sub').textContent = `Rang ${rk.r} — ${rk.name}`;
  document.getElementById('lvlup').classList.add('show');
}

function closeLvlUp(){ document.getElementById('lvlup').classList.remove('show'); }

// ══════════════════════════
// NAV
// ══════════════════════════
function navDay(d){ curDay = Math.max(1, Math.min(17, curDay+d)); renderQuests(curDay); renderMap(); }

// ══════════════════════════
// INIT
// ══════════════════════════
lastLv = getLv(S.xp).lv;
renderRoutine();
renderQuests(curDay);
renderMap();
updateUI();
</script>
</body>
</html>