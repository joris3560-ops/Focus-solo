function getArc(d){ for(let a of ARCS) if(d>=a.days[0]&&d<=a.days[1]) return a; return ARCS[0]; }

function getLv(xp){
  let lv=1, need=100, tot=0;
  while(tot+need<=xp){ tot+=need; lv++; need=Math.floor(need*1.35); }
  return { lv, cur:xp-tot, need };
}

function getRank(lv){ let r=RANKS[0]; for(let rk of RANKS) if(lv>=rk.minLv) r=rk; return r; }

