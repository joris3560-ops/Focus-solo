  document.getElementById('hrank').style.color = rk.color;
  document.getElementById('hrank').style.textShadow = `0 0 20px ${rk.color}66`;
  document.getElementById('hrank-name').textContent = rk.name;
  if(lv > lastLv){ lastLv=lv; showLvlUp(lv); }
}

