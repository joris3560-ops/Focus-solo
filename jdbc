<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SYSTEM — ARC VACANCES 17J</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&family=Noto+Sans+KR:wght@400;700&display=swap');

:root {
  --void: #000308;
  --deep: #010814;
  --panel: #05111f;
  --panel2: #071525;
  --gate: #0066ff;
  --gate2: #0044cc;
  --glow: rgba(0,102,255,0.35);
  --glow2: rgba(0,102,255,0.15);
  --cyan: #00cfff;
  --cyan-g: rgba(0,207,255,0.2);
  --gold: #e8b84b;
  --gold-g: rgba(232,184,75,0.2);
  --green: #00ff88;
  --green-g: rgba(0,255,136,0.15);
  --red: #ff3355;
  --purple: #7b3ff5;
  --purple-g: rgba(123,63,245,0.2);
  --text: #a8c5e0;
  --text2: #4a7090;
  --border: rgba(0,102,255,0.2);
  --border2: rgba(0,102,255,0.08);
}

* { margin:0; padding:0; box-sizing:border-box; }

html { scroll-behavior: smooth; }

body {
  font-family: 'Share Tech Mono', monospace;
  background: var(--void);
  color: var(--text);
  min-height: 100vh;
  cursor: default;
  overflow-x: hidden;
}

/* ── PARTICLES BG ── */
#bg-canvas {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}

/* ── SCANLINES ── */
body::after {
  content: '';
  position: fixed;
  inset: 0;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2px,
    rgba(0,0,0,0.08) 2px,
    rgba(0,0,0,0.08) 4px
  );
  pointer-events: none;
  z-index: 999;
}

.wrap {
  position: relative;
  z-index: 1;
  max-width: 960px;
  margin: 0 auto;
  padding: 0 16px 80px;
}

/* ══════════════════════════════
   SYSTEM BOOT SCREEN
══════════════════════════════ */
#boot {
  position: fixed;
  inset: 0;
  background: var(--void);
  z-index: 9000;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24px;
  transition: opacity 0.8s;
}

.boot-text {
  font-family: 'Orbitron', monospace;
  font-size: clamp(10px, 2.5vw, 14px);
  color: var(--gate);
  letter-spacing: 6px;
  text-transform: uppercase;
  animation: boot-blink 0.8s ease-in-out infinite;
}

@keyframes boot-blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

.boot-logo {
  font-family: 'Orbitron', monospace;
  font-size: clamp(28px, 7vw, 56px);
  font-weight: 900;
  color: white;
  text-align: center;
  line-height: 1.1;
  text-shadow: 0 0 40px var(--glow), 0 0 80px var(--glow2);
  letter-spacing: 4px;
}

.boot-bar-wrap {
  width: 280px;
  height: 3px;
  background: rgba(255,255,255,0.05);
  border-radius: 2px;
  overflow: hidden;
}

.boot-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--gate), var(--cyan));
  border-radius: 2px;
  width: 0%;
  box-shadow: 0 0 12px var(--glow);
  transition: width 0.05s linear;
}

/* ══════════════════════════════
   TOP HEADER
══════════════════════════════ */
.sys-header {
  padding: 40px 0 28px;
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: start;
  gap: 20px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 32px;
  animation: fadeUp 0.6s ease 1.2s both;
}

@keyframes fadeUp {
  from { opacity:0; transform:translateY(16px); }
  to { opacity:1; transform:translateY(0); }
}

.sys-label {
  font-size: 9px;
  color: var(--gate);
  letter-spacing: 5px;
  text-transform: uppercase;
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.sys-label::before {
  content: '';
  width: 20px; height: 1px;
  background: var(--gate);
}

.sys-title {
  font-family: 'Orbitron', monospace;
  font-size: clamp(22px, 5vw, 40px);
  font-weight: 900;
  color: white;
  letter-spacing: 2px;
  line-height: 1.1;
  text-shadow: 0 0 30px var(--glow);
}

.sys-title span { color: var(--cyan); }

.sys-subtitle {
  margin-top: 8px;
  font-size: 10px;
  color: var(--text2);
  letter-spacing: 4px;
}

/* ── HUNTER STATUS (top right) ── */
.hunter-card {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 3px;
  padding: 16px 20px;
  text-align: right;
  min-width: 180px;
  position: relative;
  overflow: hidden;
  box-shadow: 0 0 30px var(--glow2);
}

.hunter-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--gate), var(--cyan));
}

.h-rank {
  font-family: 'Orbitron', monospace;
  font-size: 22px;
  font-weight: 900;
  color: white;
  text-shadow: 0 0 20px var(--glow);
}

.h-rank-label { font-size: 9px; color: var(--text2); letter-spacing: 3px; }

.h-lv {
  margin-top: 10px;
  font-size: 11px;
  color: var(--cyan);
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 6px;
}

.h-lv-num {
  font-family: 'Orbitron', monospace;
  font-size: 20px;
  font-weight: 700;
  color: var(--cyan);
  text-shadow: 0 0 15px var(--cyan-g);
}

/* ══════════════════════════════
   XP BAR
══════════════════════════════ */
.xp-panel {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 3px;
  padding: 18px 22px;
  margin-bottom: 20px;
  animation: fadeUp 0.6s ease 1.3s both;
}

.xp-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.xp-tag { font-size: 9px; color: var(--text2); letter-spacing: 3px; }
.xp-nums { font-size: 12px; color: var(--gold); }
.xp-nums strong { font-family: 'Orbitron', monospace; font-size: 15px; }

.xp-track {
  height: 6px;
  background: rgba(255,255,255,0.04);
  border-radius: 3px;
  overflow: hidden;
  border: 1px solid var(--border2);
}

.xp-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--gate2), var(--gate), var(--cyan));
  border-radius: 3px;
  transition: width 1s cubic-bezier(0.4,0,0.2,1);
  position: relative;
  box-shadow: 0 0 10px var(--glow);
}

.xp-fill::after {
  content: '';
  position: absolute;
  top: 0; right: 0;
  width: 20px; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4));
  border-radius: 3px;
}

.stats-strip {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  margin-top: 14px;
  background: var(--border2);
  border: 1px solid var(--border2);
  border-radius: 2px;
  overflow: hidden;
}

.stat-chip {
  background: var(--panel2);
  padding: 10px 8px;
  text-align: center;
}

.stat-chip-val {
  font-family: 'Orbitron', monospace;
  font-size: 16px;
  font-weight: 700;
  color: var(--cyan);
  display: block;
  text-shadow: 0 0 10px var(--cyan-g);
}

.stat-chip-label { font-size: 8px; color: var(--text2); letter-spacing: 2px; margin-top: 3px; }

/* ══════════════════════════════
   SECTION TITLES
══════════════════════════════ */
.sec-title {
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 32px 0 14px;
  animation: fadeUp 0.5s ease both;
}

.sec-title-line {
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, var(--border), transparent);
}

.sec-title h2 {
  font-family: 'Orbitron', monospace;
  font-size: 11px;
  font-weight: 700;
  color: var(--gate);
  letter-spacing: 4px;
  text-transform: uppercase;
  white-space: nowrap;
}

.sec-icon {
  width: 26px; height: 26px;
  border: 1px solid var(--gate);
  display: flex; align-items: center; justify-content: center;
  font-size: 11px;
  flex-shrink: 0;
  box-shadow: 0 0 12px var(--glow2), inset 0 0 8px var(--glow2);
}

/* ══════════════════════════════
   ROUTINE
══════════════════════════════ */
.routine-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 6px;
}

@media(max-width:600px) { .routine-list { grid-template-columns: 1fr; } }

.r-item {
  background: var(--panel2);
  border: 1px solid var(--border2);
  border-left: 3px solid var(--gate2);
  padding: 11px 14px;
  display: flex;
  align-items: center;
  gap: 12px;
  cursor: pointer;
  transition: all 0.18s;
  user-select: none;
  border-radius: 2px;
}

.r-item:hover { border-left-color: var(--cyan); background: #07192a; }
.r-item.done { border-left-color: var(--green); background: #021208; opacity:0.7; }

.r-cb {
  width: 16px; height: 16px;
  border: 1px solid var(--text2);
  border-radius: 1px;
  display: flex; align-items: center; justify-content: center;
  font-size: 9px;
  flex-shrink: 0;
  transition: all 0.15s;
}

.r-item.done .r-cb { background: var(--green); border-color: var(--green); color: #001a0a; }
.r-text { font-size: 11px; color: var(--text); letter-spacing: 0.5px; }
.r-item.done .r-text { text-decoration: line-through; color: var(--text2); }
.r-time { font-size: 9px; color: var(--text2); margin-left: auto; white-space: nowrap; }

/* ══════════════════════════════
   DAY NAVIGATOR
══════════════════════════════ */
.day-nav {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
}

.nav-btn {
  width: 34px; height: 34px;
  background: var(--panel);
  border: 1px solid var(--border);
  color: var(--text2);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  font-size: 12px;
  transition: all 0.15s;
  flex-shrink: 0;
  border-radius: 2px;
}

.nav-btn:hover { border-color: var(--cyan); color: var(--cyan); box-shadow: 0 0 12px var(--cyan-g); }

.day-center {
  flex: 1;
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 2px;
  padding: 12px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  box-shadow: 0 0 20px var(--glow2);
  position: relative;
  overflow: hidden;
}

.day-center::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--glow2) 0%, transparent 60%);
}

.day-big {
  font-family: 'Orbitron', monospace;
  font-size: 22px;
  font-weight: 900;
  color: white;
  text-shadow: 0 0 20px var(--glow);
  position: relative;
}

.day-arc {
  text-align: right;
  position: relative;
}

.day-arc-name {
  font-size: 9px;
  color: var(--gate);
  letter-spacing: 3px;
  text-transform: uppercase;
}

.day-arc-theme {
  font-size: 10px;
  color: var(--text2);
  margin-top: 3px;
  max-width: 200px;
  text-align: right;
}

/* Quest progress */
.qprog {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 12px;
  font-size: 9px;
  color: var(--text2);
  letter-spacing: 2px;
}

.qprog-bar {
  flex: 1;
  height: 3px;
  background: var(--border2);
  border-radius: 2px;
  overflow: hidden;
}

.qprog-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--gate), var(--cyan));
  border-radius: 2px;
  transition: width 0.5s;
  box-shadow: 0 0 6px var(--glow);
}

/* ══════════════════════════════
   QUEST CARDS
══════════════════════════════ */
.quest-grid {
  display: grid;
  grid-template-columns: repeat(3,1fr);
  gap: 10px;
}

@media(max-width:640px) { .quest-grid { grid-template-columns: 1fr; } }

.q-card {
  background: var(--panel);
  border: 1px solid var(--border2);
  border-radius: 3px;
  padding: 18px 16px;
  cursor: pointer;
  transition: all 0.2s;
  user-select: none;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

/* colored top stripe */
.q-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
}

.q-card.phys::before  { background: linear-gradient(90deg, #ff4444, #ff8800); }
.q-card.ment::before  { background: linear-gradient(90deg, var(--gate), var(--purple)); }
.q-card.evol::before  { background: linear-gradient(90deg, var(--cyan), var(--green)); }

/* glow on hover */
.q-card.phys:hover  { border-color: rgba(255,100,0,0.4); box-shadow: 0 0 20px rgba(255,100,0,0.12); }
.q-card.ment:hover  { border-color: var(--border); box-shadow: 0 0 20px var(--glow2); }
.q-card.evol:hover  { border-color: rgba(0,207,255,0.3); box-shadow: 0 0 20px var(--cyan-g); }

.q-card:hover { transform: translateY(-2px); }
.q-card.done { opacity: 0.55; }
.q-card.done .q-title { text-decoration: line-through; }

.q-type-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.q-type {
  font-size: 8px;
  letter-spacing: 4px;
  text-transform: uppercase;
}

.phys .q-type  { color: #ff7744; }
.ment .q-type  { color: var(--gate); }
.evol .q-type  { color: var(--cyan); }

.q-check {
  width: 20px; height: 20px;
  border: 1px solid var(--text2);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 10px;
  transition: all 0.2s;
  flex-shrink: 0;
}

.q-card:hover .q-check { border-color: var(--green); }
.q-card.done .q-check { background: var(--green); border-color: var(--green); color: #001a0a; }

.q-icon { font-size: 20px; }
.q-title { font-size: 13px; font-weight: 700; color: white; line-height: 1.3; font-family: 'Orbitron', monospace; font-size: 11px; }
.q-desc { font-size: 10px; color: var(--text2); line-height: 1.6; flex: 1; }

.q-xp {
  font-size: 10px;
  color: var(--gold);
  display: flex;
  align-items: center;
  gap: 4px;
}

/* ══════════════════════════════
   REWARD PANEL
══════════════════════════════ */
.reward-panel {
  margin-top: 12px;
  background: linear-gradient(135deg, #08001a, #030d1a);
  border: 1px solid rgba(123,63,245,0.35);
  border-radius: 3px;
  padding: 14px 18px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  box-shadow: 0 0 25px var(--purple-g);
  flex-wrap: wrap;
}

.reward-label { font-size: 8px; color: var(--purple); letter-spacing: 3px; margin-bottom: 5px; }
.reward-text  { font-size: 11px; color: var(--text); }
.reward-xp    { font-family: 'Orbitron', monospace; font-size: 16px; color: var(--gold); white-space: nowrap; text-shadow: 0 0 12px var(--gold-g); }

/* ══════════════════════════════
   17 DAY MAP
══════════════════════════════ */
.map-grid {
  display: grid;
  grid-template-columns: repeat(17,1fr);
  gap: 4px;
}

@media(max-width:600px) {
  .map-grid { grid-template-columns: repeat(9,1fr); }
}

.map-day {
  aspect-ratio: 1;
  background: var(--panel2);
  border: 1px solid var(--border2);
  border-radius: 2px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.15s;
  font-size: 10px;
  color: var(--text2);
  position: relative;
}

.map-day:hover { border-color: var(--gate); color: var(--cyan); box-shadow: 0 0 10px var(--glow2); }
.map-day.active { border-color: var(--cyan); color: var(--cyan); background: #041a2e; box-shadow: 0 0 14px var(--cyan-g); }
.map-day.done { border-color: var(--green); color: var(--green); background: #001a0a; }
.map-day.boss { border-color: var(--gold); }

.map-day-n { font-family: 'Orbitron', monospace; font-size: 11px; font-weight: 700; }
.map-day-s { font-size: 7px; margin-top: 1px; }

/* ══════════════════════════════
   RULES
══════════════════════════════ */
.rules-wrap {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

@media(max-width:500px) { .rules-wrap { grid-template-columns: 1fr; } }

.rule-box {
  background: var(--panel2);
  border: 1px solid var(--border2);
  border-radius: 3px;
  padding: 16px;
}

.rule-box.no  { border-left: 3px solid var(--red); }
.rule-box.yes { border-left: 3px solid var(--green); }

.rule-head {
  font-size: 8px;
  letter-spacing: 3px;
  text-transform: uppercase;
  margin-bottom: 10px;
}

.rule-box.no .rule-head  { color: var(--red); }
.rule-box.yes .rule-head { color: var(--green); }

.rule-line {
  font-size: 11px;
  color: var(--text);
  padding: 5px 0;
  border-bottom: 1px solid var(--border2);
  display: flex;
  align-items: center;
  gap: 8px;
}

.rule-line:last-child { border-bottom: none; }
.dot-r { width: 4px; height: 4px; border-radius: 50%; background: var(--red); flex-shrink: 0; }
.dot-g { width: 4px; height: 4px; border-radius: 50%; background: var(--green); flex-shrink: 0; }

/* ══════════════════════════════
   TOAST
══════════════════════════════ */
#toast {
  position: fixed;
  top: 20px; right: 20px;
  z-index: 8000;
  padding: 12px 20px;
  background: var(--panel);
  border: 1px solid var(--green);
  border-radius: 3px;
  font-size: 12px;
  color: var(--green);
  box-shadow: 0 0 30px var(--green-g);
  transform: translateX(130%);
  transition: transform 0.4s cubic-bezier(0.4,0,0.2,1);
  max-width: 280px;
  letter-spacing: 1px;
}

#toast.show { transform: translateX(0); }
#toast.gold { border-color: var(--gold); color: var(--gold); box-shadow: 0 0 30px var(--gold-g); }
#toast.purple { border-color: var(--purple); color: var(--purple); box-shadow: 0 0 30px var(--purple-g); }

/* ══════════════════════════════
   LEVEL UP OVERLAY
══════════════════════════════ */
#lvlup {
  position: fixed;
  inset: 0;
  z-index: 7000;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(0,3,8,0.95);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.4s;
}

#lvlup.show { opacity: 1; pointer-events: all; }

.lvlup-ring {
  width: 160px; height: 160px;
  border-radius: 50%;
  border: 2px solid var(--gate);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 60px var(--glow), inset 0 0 40px var(--glow2);
  animation: ring-pulse 1.5s ease-in-out infinite;
  margin-bottom: 32px;
  position: relative;
}

@keyframes ring-pulse {
  0%,100% { box-shadow: 0 0 40px var(--glow), inset 0 0 20px var(--glow2); }
  50% { box-shadow: 0 0 80px var(--glow), inset 0 0 50px var(--glow2), 0 0 120px rgba(0,102,255,0.2); }
}

.lvlup-ring::before, .lvlup-ring::after {
  content: '';
  position: absolute;
  border-radius: 50%;
  border: 1px solid rgba(0,102,255,0.3);
}

.lvlup-ring::before { width: 180px; height: 180px; }
.lvlup-ring::after  { width: 200px; height: 200px; opacity: 0.5; }

.lvlup-lv {
  font-family: 'Orbitron', monospace;
  font-size: 11px;
  color: var(--text2);
  letter-spacing: 4px;
  text-transform: uppercase;
}

.lvlup-num {
  font-family: 'Orbitron', monospace;
  font-size: 56px;
  font-weight: 900;
  color: white;
  text-shadow: 0 0 40px var(--glow);
  line-height: 1;
}

.lvlup-title {
  font-family: 'Orbitron', monospace;
  font-size: clamp(16px, 4vw, 28px);
  font-weight: 700;
  color: var(--cyan);
  letter-spacing: 4px;
  text-shadow: 0 0 30px var(--cyan-g);
  text-align: center;
}

.lvlup-sub {
  font-size: 11px;
  color: var(--text2);
  letter-spacing: 3px;
  margin-top: 12px;
  text-align: center;
}

.lvlup-close {
  margin-top: 40px;
  border: 1px solid var(--border);
  background: transparent;
  color: var(--text2);
  padding: 10px 32px;
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px;
  letter-spacing: 3px;
  cursor: pointer;
  transition: all 0.2s;
