  document.getElementById('s-days').textContent = S.sdays;
  document.getElementById('s-quests').textContent = S.sqsts;
  document.getElementById('s-streak').textContent = S.streak;
  document.getElementById('hlv').textContent = lv;
  const rk = getRank(lv);
